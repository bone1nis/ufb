# Файл: .editorconfig
# EditorConfig помогает поддерживать единый стиль кода в разных редакторах и IDE.
# https://editorconfig.org

# Это корневой файл конфигурации.
root = true

# ==================================================================
#                  ГЛОБАЛЬНЫЕ ПРАВИЛА ДЛЯ ВСЕХ ФАЙЛОВ
# ==================================================================
[*]
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf
charset = utf-8

# ==================================================================
#                      ПРАВИЛА ДЛЯ C#
# ==================================================================
[*.cs]
indent_size = 4
max_line_length = 120

# ==================================================================
#                      ПРАВИЛА ДЛЯ XML / CSPROJ
# ==================================================================
[*.{xml,csproj,props,targets}]
indent_size = 2
max_line_length = 120

# ==================================================================
#                      ПРАВИЛА ДЛЯ JSON
# ==================================================================
[*.json]
indent_size = 2

# ==================================================================
#                      ПРАВИЛА ДЛЯ YAML-ФАЙЛОВ
# ==================================================================
[*.yml]
indent_size = 2
max_line_length = 120

# ==================================================================
#                       ПРАВИЛА ДЛЯ DOCKERFILE
# ==================================================================
[**/Dockerfile,*.Dockerfile]
indent_size = 2
max_line_length = 120

# ==================================================================
#                      ПРАВИЛА ДЛЯ SHELL-СКРИПТОВ
# ==================================================================
[*.sh]
indent_size = 2
