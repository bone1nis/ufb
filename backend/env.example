# =================================================================================
# КОНФИГУРАЦИЯ ОКРУЖЕНИЯ - team-1/backend
# =================================================================================
# Назначение:
#   Этот файл является контрактом между командным репозиторием и CI/CD-платформой.
#   verify job проверяет наличие обязательных переменных, а deploy job генерирует
#   runtime .env для backend-контейнера.
#
# Роли файлов:
#   .gitlab-ci.yml - выбирает сценарий деплоя команды
#   env.example    - описывает контракт переменных и безопасные дефолты
#   GitLab UI      - хранит секреты и редко меняющиеся инфраструктурные значения
#
# Флаги:
#   # ci-only      - только для pipeline, НЕ писать в runtime .env
#   # optional     - не падать в verify если пусто; не писать в .env если пусто
#   # default:VAL  - подставить VAL, если переменная пуста
#   # type:file    - проверить файл, НЕ писать в .env
#   # generated    - создаётся в runtime, не проверять в verify
#   # check:V1,V2  - проверить наличие этих переменных в GitLab CI
#
# Важно:
#   DEPLOY_MODE, NEEDS_DB и DB_TYPE НЕ являются ci-only, потому что приложение
#   читает их в runtime и на их основе показывает активный режим и endpoint'ы.
# =================================================================================

# ---------------------------------------------------------------------------------
# 1. ИНФРАСТРУКТУРА
# ---------------------------------------------------------------------------------
SSH_PRIVATE_KEY=                            # type:file ci-only check:SSH_PRIVATE_KEY
SSH_USER=deployer                           # ci-only default:deployer
SSH_HOST=                                   # ci-only check:SSH_HOST
SSH_PORT=22                                 # ci-only default:22

# ---------------------------------------------------------------------------------
# 2. ПЛАТФОРМА
# ---------------------------------------------------------------------------------
TEAM_SLUG=                                  # ci-only check:TEAM_SLUG
ENVIRONMENT=hackathon                       # ci-only default:hackathon
DOMAIN=hack.kam-dev.ru                      # ci-only default:hack.kam-dev.ru
COMPOSE_PROJECT_NAME=                       # generated
PODMAN_NETWORK=hackathon-network            # ci-only default:hackathon-network

# ---------------------------------------------------------------------------------
# 3. РАННЕРЫ / ОБРАЗА
# ---------------------------------------------------------------------------------
DEPLOY_RUNNER_TAG=                          # ci-only check:DEPLOY_RUNNER_TAG
BUILD_RUNNER_TAG=                           # ci-only check:BUILD_RUNNER_TAG
BASH_IMAGE=bash:alpine3.23                  # ci-only default:bash:alpine3.23
KANIKO_IMAGE=gcr.io/kaniko-project/executor:debug # ci-only default:gcr.io/kaniko-project/executor:debug
DOCKER_IMAGE=docker:29.1.2-alpine3.23       # ci-only default:docker:29.1.2-alpine3.23
PLATFORM_REPO_PATH=hackathon-2026/platform  # ci-only default:hackathon-2026/platform

# ---------------------------------------------------------------------------------
# 4. МАТРИЦА СЦЕНАРИЯ
# ---------------------------------------------------------------------------------
# DEPLOY_MODE:
#   web  - HTTP API / backend
#   bot  - backend в режиме бота
#   full - расширенный runtime-сценарий
#
# NEEDS_DB:
#   false - БД не используется
#   true  - БД используется, тип задаётся через DB_TYPE
#
# DB_TYPE:
#   none     - БД не используется
#   sqlite   - файловая SQLite БД внутри backend volume
#   postgres - отдельный PostgreSQL контейнер
#
# Эти переменные попадают в runtime .env, чтобы backend мог показать активный режим.
DEPLOY_MODE=web                             # default:web
NEEDS_DB=false                              # default:false
DB_TYPE=none                                # default:none

# ---------------------------------------------------------------------------------
# 5. POSTGRESQL
# ---------------------------------------------------------------------------------
# Используется только если:
#   NEEDS_DB=true
#   DB_TYPE=postgres
#
# В остальных сценариях deploy script не должен писать эти переменные
# в runtime .env backend-контейнера.
DB_HOST=postgres                            # generated default:postgres
DB_PORT=5432                                # default:5432
DB_NAME=hack_backend                        # default:hack_backend
DB_USER=hack_user                           # default:hack_user
DB_PASS=                                    # optional check:DB_PASS

# Альтернативная строка подключения для .NET.
# В текущем sample backend сам собирает connection string из DB_*,
# поэтому эта переменная не обязательна.
ConnectionStrings__DefaultConnection=       # optional check:ConnectionStrings__DefaultConnection

# ---------------------------------------------------------------------------------
# 6. SQLITE
# ---------------------------------------------------------------------------------
# Используется только если:
#   NEEDS_DB=true
#   DB_TYPE=sqlite
#
# Файл БД хранится в volume, примонтированном в /app/data.
SQLITE_PATH=/app/data/app.db                # default:/app/data/app.db

# ---------------------------------------------------------------------------------
# 7. ASP.NET CORE
# ---------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production           # default:Production
ASPNETCORE_URLS=http://+:8080               # default:http://+:8080

# ---------------------------------------------------------------------------------
# 8. HEALTHCHECK
# ---------------------------------------------------------------------------------
# Эти переменные нужны deploy script, а не приложению, поэтому ci-only.
CONTAINER_PORT=8080                         # ci-only default:8080
HEALTHCHECK_PATH=/health                    # ci-only default:/health

# ---------------------------------------------------------------------------------
# 9. BOT
# ---------------------------------------------------------------------------------
# Используется если:
#   DEPLOY_MODE=bot
#   или DEPLOY_MODE=full и приложение включает bot runtime
#
# BOT_TOKEN должен храниться как masked GitLab CI/CD variable.
BOT_TOKEN=                                  # optional check:BOT_TOKEN
BOT_MODE=polling                            # optional default:polling

## END OF CI VARIABLES ##
