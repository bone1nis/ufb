# Локальная разработка (Vite читает из .env).
# На CI см. корневой env.example в этом каталоге: там API_BASE_URL и EXTRA_BUILD_ARGS
# пробрасывают в docker build один раз как VITE_API_URL — второй раз тот же URL в GitLab не дублируй.

VITE_API_URL=http://localhost:8080

# Полная ссылка «Открыть бот ВКонтакте». Для docker-сборки — в .env.production (файл .env в образ не копируется).
VITE_VK_BOT_URL=https://vk.com/im?sel=-238684561
